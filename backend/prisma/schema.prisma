generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Character {
  id            Int              @id @default(autoincrement())
  name          String
  codeName      String?
  ability       String
  level         String
  status        String
  description   String?
  avatar        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  events        EventCharacter[]
  missions      MissionCharacter[]
  levelHistories LevelHistory[]
}

model Event {
  id                 Int              @id @default(autoincrement())
  title              String
  type               String
  level              String
  date               DateTime
  location           String
  description        String
  result             String?
  disposalStatus     String           @default("待处置")
  disposalConclusion String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  characters         EventCharacter[]
  missions           Mission[]
  levelHistories     LevelHistory[]
}

model Mission {
  id             Int              @id @default(autoincrement())
  title          String
  description    String
  priority       String
  status         String
  dueDate        DateTime
  eventId        Int?
  event          Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  characters     MissionCharacter[]
  levelHistories LevelHistory[]
}

model EventCharacter {
  eventId        Int
  characterId    Int
  role           String?
  contribution   String?
  missionResult  String?
  collaboration  String?
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([eventId, characterId])
}

model MissionCharacter {
  missionId   Int
  characterId Int
  role        String?
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([missionId, characterId])
}

model LevelHistory {
  id          Int      @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  oldLevel    String
  newLevel    String
  reason      String
  description String?
  eventId     Int?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  missionId   Int?
  mission     Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}
