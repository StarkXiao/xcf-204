generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Character {
  id          Int      @id @default(autoincrement())
  name        String
  codeName    String?
  ability     String
  level       String
  status      String
  description String?
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      EventCharacter[]
  missions    MissionCharacter[]
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  type        String
  level       String
  date        DateTime
  location    String
  description String
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  characters  EventCharacter[]
}

model Mission {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  priority    String
  status      String
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  characters  MissionCharacter[]
}

model EventCharacter {
  eventId     Int
  characterId Int
  role        String?
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([eventId, characterId])
}

model MissionCharacter {
  missionId   Int
  characterId Int
  role        String?
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([missionId, characterId])
}
